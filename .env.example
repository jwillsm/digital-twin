# === Required ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=123456789

# === LLM Configuration (choose OpenAI or Gemini) ===
# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Gemini settings (optional, for Google's Generative Language API)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=models/text-bison-001

# === Database ===
# SQLite for local dev (zero setup)
DATABASE_URL=sqlite:///./data/digital_twin.db

# === Vector store ===
CHROMA_PATH=./data/chroma

# === Whisper model size ===
# Options: tiny, base, small, medium (larger = more accurate, slower)
WHISPER_MODEL=base

# === Optional: ngrok authtoken for stable URLs ===
# NGROK_AUTHTOKEN=your_ngrok_token_here
